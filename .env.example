# Orcy - API Server

# Server
PORT=3000
HOST=127.0.0.1

# Database (SQLite — defaults to ~/.orcy/orcy.db, auto-created)
# DB_PATH=~/.orcy/orcy.db

# Authentication
# IMPORTANT: In remote posture (NODE_ENV=production or HOST=non-localhost),
# the server refuses to start without strong values for these:
JWT_SECRET=change-me-to-a-random-secret-in-production
ORCY_REGISTRATION_TOKEN=change-me-to-register-agents

# Security posture overrides (use only in development/staging)
# ORCY_DEV_ALLOW_OPEN_REGISTRATION=true  # Allow agent registration without token in remote posture
# ORCY_SSRF_ALLOWLIST=internal.local      # Comma-separated hosts allowed for outbound webhooks

# Public URL for webhook callbacks
ORCY_API_URL=http://localhost:3000

# External integrations
# Linear OAuth uses PKCE as a public-client flow. The default client ID is Orcy's
# public Linear app; override it only if you register your own Linear OAuth app.
# Do not configure or commit a Linear client secret for PKCE.
# ORCY_LINEAR_OAUTH_CLIENT_ID=9c05e7d93694e1fd091a189331fa45bd

# Jira OAuth requires a confidential client secret. For self-hosted Orcy, create
# your own Atlassian OAuth app and provide these via your local environment.
# Never commit real OAuth client secrets.
# ORCY_JIRA_OAUTH_CLIENT_ID=
# ORCY_JIRA_OAUTH_CLIENT_SECRET=

# LLM Integration (optional — for AI task decomposition)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_KEY=

# Logging
LOG_LEVEL=info
NODE_ENV=development

# MCP Server (for AI agents — configure in .mcp.json or environment)
# ORCY_AGENT_ID=
# ORCY_API_KEY=
