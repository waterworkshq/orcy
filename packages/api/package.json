{
  "name": "@orcy/api",
  "version": "1.0.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "drizzle"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "orcy-api": "./dist/index.js"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:seed": "tsx ../../scripts/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "@orcy/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-raw-body": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.2",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.5",
    "pino": "^9.0.0",
    "uuid": "^14.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.12.0",
    "@types/nodemailer": "^8.0.0",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^11.0.0",
    "sql.js": "^1.10.3",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
