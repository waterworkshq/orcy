{
  "hooks": {
    "after:bump": "pnpm exec git-cliff --tag v${version} -o CHANGELOG.md && node scripts/trim-changelog.mjs"
  },
  "git": {
    "commitMessage": "chore(release): v${version}",
    "tagName": "v${version}"
  },
  "github": {
    "release": true,
    "releaseName": "v${version}",
    "releaseNotes": "pnpm exec git-cliff --tag v${version} --current -o -"
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "conventionalcommits"
    }
  }
}
