{
  "hooks": {
    "after:bump": "pnpm exec git-cliff --tag v${version} -o CHANGELOG.md && node scripts/trim-changelog.mjs"
  },
  "git": {
    "tagName": "v${version}",
    "commitMessage": "chore(release): v${version}"
  },
  "github": {
    "release": true,
    "releaseName": "V${version}",
    "releaseNotes": "pnpm exec git-cliff -s header ${latestTag}..v${version}"
  }
}
